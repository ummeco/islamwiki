# Islam.wiki Content Scrapers — Environment Variables
# API keys for content sources

# Quran.com (if rate-limited to get an API key)
QURANCOM_API_KEY=

# QuranEnc.com
QURANENC_API_KEY=

# sunnah.com (if they require API key in future)
SUNNAH_API_KEY=

# Anthropic (for IWT generation pipeline)
ANTHROPIC_API_KEY=

# Database (for seeding)
DATABASE_URL=postgresql://user:pass@localhost:5432/islamwiki
HASURA_ADMIN_SECRET=
