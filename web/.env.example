# Islam.wiki — Environment Variables
# Copy this to .env.local and fill in values

# Auth (Phase 2 — Hasura Auth)
NEXT_PUBLIC_HASURA_URL=https://api.islam.wiki/graphql
HASURA_ADMIN_SECRET=

# Audio (no key needed — EveryAyah.com is a free CDN)
# NEXT_PUBLIC_AUDIO_CDN=https://everyayah.com/data

# Search (Phase 6 — Meilisearch)
NEXT_PUBLIC_MEILISEARCH_URL=https://search.islam.wiki
NEXT_PUBLIC_MEILISEARCH_KEY=

# Monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Iron-session (Phase 1 only — remove when migrating to Hasura Auth)
SESSION_SECRET=
