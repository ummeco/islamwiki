# Islam.wiki — Local Dev Environment
# Copy to .env.local and fill in values

# ── Hasura GraphQL (via nSelf local proxy) ──
NEXT_PUBLIC_HASURA_URL=https://api.islamwiki.local.nself.org:8543/v1/graphql
HASURA_ADMIN_URL=https://api.islamwiki.local.nself.org:8543/v1/graphql
HASURA_GRAPHQL_ADMIN_SECRET=

# ── Auth (Hasura Auth via nSelf) ──
NEXT_PUBLIC_AUTH_URL=https://auth.local.nself.org:8543

# ── Remote Schema (Hasura → Vercel/Next.js) ──
REMOTE_SCHEMA_SECRET=

# ── Search (Meilisearch — leave empty to use client-side fallback) ──
# Retrieve keys: nself plugin info meilisearch  (or the Meilisearch Cloud dashboard)
# MEILISEARCH_KEY must be a search-only key (not the master key)
MEILISEARCH_URL=
MEILISEARCH_KEY=

# ── Audio ──
# Defaults to https://everyayah.com/data if not set
NEXT_PUBLIC_AUDIO_BASE_URL=

# ── AI (Anthropic Claude) ──
ANTHROPIC_API_KEY=

# ── Sentry ──
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Base URL (for callback URLs in auth flows) ──
NEXT_PUBLIC_BASE_URL=https://www.islamwiki.local.nself.org:8543
